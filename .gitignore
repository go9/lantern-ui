/_build/
/deps/
/cover/
/doc/
*.ez
lantern_ui-*.tar

# Crash dumps
erl_crash.dump

# Editor / language server
/.elixir_ls/
/.lexical/

# Local, machine-specific config
flicker.toml
.env

# Symlinked into worktrees; a trailing-slash pattern matches a DIRECTORY,
# not a symlink, so these need bare entries too.
/deps
/_build
